# AgriGPT Backend Environment Variables Example

# ==========================================
# API KEY ARRAYS (For KeyRotator/Failover)
# Format: "key1,key2,key3" or "['key1', 'key2']"
# ==========================================

# Groq LLM API Keys (Round-Robin & Fallback)
GROQ_API_KEYS="gsk_12345,gsk_67890"

# OpenRouter LLM API Keys (Round-Robin & Fallback)
OPENROUTER_API_KEYS="sk-or-v1-abc,sk-or-v1-def"

# OpenWeatherMap API Keys
WEATHER_API_KEYS="weather_key_1,weather_key_2"

# Tavily Advanced Web Search API Keys
TAVILY_API_KEYS="tvly-abc,tvly-def"

# ==========================================
# HUGGING FACE SETTINGS
# ==========================================
# Used by sentence-transformers to avoid unauthenticated download warnings and rate-limits
HF_TOKEN="hf_YourTokenHere"

# ==========================================
# SERVER SETTINGS
# ==========================================
# Database Connection (MongoDB Atlas for production, leave blank for local SQLite fallback)
MONGO_URI="mongodb+srv://username:password@cluster0.mongodb.net/?retryWrites=true&w=majority"

# Optional: Change to your deployed Vercel frontend URL in production
BACKEND_CORS_ORIGINS="http://localhost:3000,https://agrigpt.vercel.app"
